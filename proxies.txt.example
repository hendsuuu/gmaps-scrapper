# proxies.txt – one proxy per line
# Supported formats:
#   http://user:pass@host:port
#   http://host:port
#   host:port  (http:// added automatically)
#
# Lines starting with # and blank lines are ignored.
#
# Examples:
# http://alice:secret123@proxy1.example.com:8080
# http://bob:pass456@proxy2.example.com:3128
# 203.0.113.10:8888
